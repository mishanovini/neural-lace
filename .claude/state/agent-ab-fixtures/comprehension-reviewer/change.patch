diff --git a/src/lib/rate-limiter.ts b/src/lib/rate-limiter.ts
index 1111111..2222222 100644
--- a/src/lib/rate-limiter.ts
+++ b/src/lib/rate-limiter.ts
@@ -10,6 +10,22 @@ const windows = new Map<string, number[]>();
+export function checkLimit(orgId: string, now: number): boolean {
+  // prune entries outside the rolling 60s window
+  const events = (windows.get(orgId) ?? []).filter((t) => now - t < 60_000);
+  if (events.length >= 100) {
+    windows.set(orgId, events);
+    return false;
+  }
+  events.push(now);
+  windows.set(orgId, events);
+  return true;
+}
+
+export function resetOrg(orgId: string): void {
+  windows.delete(orgId);
+}
diff --git a/src/services/notifier.ts b/src/services/notifier.ts
