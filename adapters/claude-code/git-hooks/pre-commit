#!/bin/bash
# Global git pre-commit hook — security scanner for staged content.
#
# Scans for:
#   1. Credentials and secrets (API keys, tokens, private keys)
#   2. Sensitive filenames (.env, credentials.json, etc.)
#   3. Security anti-patterns common in AI-generated code
#   4. Development artifacts that shouldn't ship to production
#
# Defense in depth: pre-commit catches early, pre-push catches anything missed.
#
# This file is referenced by `git config --global core.hooksPath`
# so it runs on EVERY commit from EVERY repo on this machine.
#
# To bypass: git commit --no-verify (blocked by Claude Code's PreToolUse hook)

set -e

# ============================================================
# Built-in credential patterns (same as pre-push-scan.sh)
# ============================================================

PATTERNS=(
  # GitHub tokens
  'gh[pous]_[A-Za-z0-9_]{36,}'
  'ghs_[A-Za-z0-9_]{36,}'
  # Anthropic
  'sk-ant-api[A-Za-z0-9_-]{20,}'
  # OpenAI
  'sk-[A-Za-z0-9]{40,}'
  'sk-proj-[A-Za-z0-9_-]{40,}'
  # Stripe
  'sk_live_[A-Za-z0-9]{20,}'
  'sk_test_[A-Za-z0-9]{20,}'
  'rk_live_[A-Za-z0-9]{20,}'
  # Slack
  'xox[bprs]-[A-Za-z0-9-]{10,}'
  # AWS
  'AKIA[A-Z0-9]{16}'
  'aws_secret_acces[s]_key'
  # Google
  'AIza[A-Za-z0-9_-]{35}'
  # Twilio
  'AC[a-f0-9]{32}'
  # SendGrid
  'SG\.[A-Za-z0-9_-]{20,}'
  # Mailgun
  'key-[a-f0-9]{32}'
  # JWT / Bearer tokens
  'eyJ[A-Za-z0-9_-]{20,}\.eyJ[A-Za-z0-9_-]{20,}\.'
  # Private keys
  'BEGIN (RSA|OPENSSH|DSA|EC|PGP) PRIVATE KEY'
  # Supabase service role (heuristic)
  'service.role.*eyJ[A-Za-z0-9_-]+'
)

# Sensitive filenames that should never be committed
SENSITIVE_FILES=(
  '\.env$'
  '\.env\.'
  'credentials\.json$'
  'secrets\.ya?ml$'
  '\.pem$'
  'id_rsa$'
  'id_ed25519$'
  '\.p12$'
  '\.pfx$'
  'auth-state\.json$'
)

# ============================================================
# Load custom patterns (personal + team)
# ============================================================

EXTRA_PATTERNS=()

if [ -f "$HOME/.claude/sensitive-patterns.local" ]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    EXTRA_PATTERNS+=("$line")
  done < "$HOME/.claude/sensitive-patterns.local"
fi

if [ -d "$HOME/.claude/business-patterns.d" ]; then
  for pfile in "$HOME/.claude/business-patterns.d"/*.txt; do
    [ -f "$pfile" ] || continue
    while IFS= read -r line; do
      [[ -z "$line" || "$line" =~ ^# ]] && continue
      EXTRA_PATTERNS+=("$line")
    done < "$pfile"
  done
fi

# ============================================================
# Scan staged files
# ============================================================

BLOCKED=0

# Check for sensitive filenames in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

for file in $STAGED_FILES; do
  for pattern in "${SENSITIVE_FILES[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo ""
      echo "================================================================"
      echo "COMMIT BLOCKED: sensitive file staged"
      echo "================================================================"
      echo ""
      echo "  File: $file"
      echo "  Pattern: $pattern"
      echo ""
      echo "  Remove with: git reset HEAD $file"
      echo ""
      BLOCKED=1
    fi
  done
done

# Early exit if sensitive files already found (don't bury the message with more output)
[ "$BLOCKED" -eq 1 ] && exit 1

# Check staged content for credential patterns
# Exclude scanner files themselves (they contain pattern definitions, not real credentials)
SAFE_FILES="pre-commit|pre-push-scan\.sh|credential-push-blocked\.sh|sensitive-patterns\.local\.example"

if [ -n "$STAGED_FILES" ]; then
  # Get the staged diff (only added lines), excluding scanner files
  STAGED_DIFF=$(git diff --cached --diff-filter=ACMR -U0 -- $(echo "$STAGED_FILES" | grep -vE "$SAFE_FILES") 2>/dev/null)

  # Combine all patterns
  ALL_PATTERNS=("${PATTERNS[@]}" "${EXTRA_PATTERNS[@]}")

  for pattern in "${ALL_PATTERNS[@]}"; do
    # Only check added lines (lines starting with +, excluding +++ headers)
    MATCHES=$(echo "$STAGED_DIFF" | grep -E '^\+[^+]' | grep -E "$pattern" 2>/dev/null | head -3)
    if [ -n "$MATCHES" ]; then
      echo ""
      echo "================================================================"
      echo "COMMIT BLOCKED: sensitive patterns detected in staged content"
      echo "================================================================"
      echo ""
      echo "  Pattern: $pattern"
      echo ""
      while IFS= read -r line; do
        # Show first 120 chars, strip the leading +
        echo "  ${line:1:120}"
      done <<< "$MATCHES"
      echo ""
      BLOCKED=1
    fi
  done
fi

if [ "$BLOCKED" -eq 1 ]; then
  echo "Options:"
  echo "  1. Remove the sensitive content and re-stage"
  echo "  2. If CERTAIN this is a false positive: git commit --no-verify"
  echo ""
  echo "Patterns loaded from:"
  echo "  - Built-in (generic credentials)"
  [ -f "$HOME/.claude/sensitive-patterns.local" ] && echo "  - ~/.claude/sensitive-patterns.local (personal)"
  [ -d "$HOME/.claude/business-patterns.d" ] && echo "  - ~/.claude/business-patterns.d/ (team)"
  echo ""
  exit 1
fi

# ============================================================
# Security anti-patterns (warnings, not blockers)
# Common in AI-generated code — catch before they ship
# ============================================================

WARNINGS=0

warn() {
  if [ "$WARNINGS" -eq 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════╗"
    echo "║  Security warnings in staged changes         ║"
    echo "╚══════════════════════════════════════════════╝"
    echo ""
  fi
  WARNINGS=$((WARNINGS + 1))
  echo "  ⚠ $1"
  echo "    $2"
  echo ""
}

# Only run on source files (not configs, docs, tests, lock files, etc.)
SOURCE_DIFF=$(git diff --cached --diff-filter=ACMR -U0 -- \
  $(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx|mjs|py|rb|go|rs|java)$' | grep -vE '(test|spec|__test__|\.test\.|\.spec\.)') \
  2>/dev/null || true)

ADDED_LINES=""
if [ -n "$SOURCE_DIFF" ]; then
  ADDED_LINES=$(echo "$SOURCE_DIFF" | grep -E '^\+[^+]' 2>/dev/null || true)
fi

if [ -n "$ADDED_LINES" ]; then

  # --- BLOCKERS (exit 1) ---

  # Supabase service role key in client-side code
  SRC_FILES_ONLY=$(echo "$STAGED_FILES" | grep -E '^src/' | grep -vE '(api/|server|middleware)' || true)
  if [ -n "$SRC_FILES_ONLY" ]; then
    SRC_DIFF=$(git diff --cached --diff-filter=ACMR -U0 -- $SRC_FILES_ONLY 2>/dev/null || true)
    if [ -n "$SRC_DIFF" ]; then
      SVC_MATCH=$(echo "$SRC_DIFF" | grep -E '^\+[^+]' | grep -iE '(SUPABASE_SERVICE_ROLE|service_role)' 2>/dev/null | head -1)
      if [ -n "$SVC_MATCH" ]; then
        echo ""
        echo "================================================================"
        echo "COMMIT BLOCKED: Supabase service role key in client code"
        echo "================================================================"
        echo ""
        echo "  ${SVC_MATCH:1:120}"
        echo ""
        echo "  The service role key bypasses RLS entirely. Client code should"
        echo "  only use NEXT_PUBLIC_SUPABASE_ANON_KEY."
        echo ""
        exit 1
      fi
    fi
  fi

  # --- WARNINGS (inform, don't block) ---

  # Hardcoded localhost URLs (AI agents frequently leave these)
  if echo "$ADDED_LINES" | grep -qE "https?://(localhost|127\.0\.0\.1|0\.0\.0\.0)(:|/|\")" 2>/dev/null; then
    warn "Hardcoded localhost URL in source code" \
         "AI agents often hardcode localhost during dev. Use env vars for API URLs."
  fi

  # Disabled security controls
  if echo "$ADDED_LINES" | grep -qE '@ts-nocheck' 2>/dev/null; then
    warn "@ts-nocheck disables ALL type checking for the file" \
         "Fix the type errors instead. This hides real bugs."
  fi

  if echo "$ADDED_LINES" | grep -qE 'dangerouslySetInnerHTML' 2>/dev/null; then
    warn "dangerouslySetInnerHTML is an XSS vector" \
         "Ensure the input is sanitized. This is the #1 XSS source in React apps."
  fi

  if echo "$ADDED_LINES" | grep -qE 'rejectUnauthorized\s*:\s*false' 2>/dev/null; then
    warn "TLS certificate validation disabled" \
         "rejectUnauthorized: false allows man-in-the-middle attacks."
  fi

  if echo "$ADDED_LINES" | grep -qE "mode:\s*['\"]no-cors['\"]" 2>/dev/null; then
    warn "no-cors mode on fetch request" \
         "This silently drops response data and masks real CORS issues."
  fi

  # Overly permissive CORS
  if echo "$ADDED_LINES" | grep -qE "Access-Control-Allow-Origin.*\*" 2>/dev/null; then
    warn "Wildcard CORS header (Access-Control-Allow-Origin: *)" \
         "This allows any website to call your API. Use specific origins."
  fi

  # RLS bypass in migrations
  MIGRATION_DIFF=$(git diff --cached --diff-filter=ACMR -U0 -- \
    $(echo "$STAGED_FILES" | grep -E '(migration|\.sql)' || echo "/dev/null") \
    2>/dev/null || true)
  if [ -n "$MIGRATION_DIFF" ]; then
    if echo "$MIGRATION_DIFF" | grep -E '^\+[^+]' | grep -qiE 'USING\s*\(\s*true\s*\)' 2>/dev/null; then
      warn "RLS policy with USING (true) — allows all rows" \
           "This effectively disables row-level security for this table."
    fi
  fi

  # Exposed error internals to client
  if echo "$ADDED_LINES" | grep -qE 'err(or)?\.stack|err(or)?\.message.*[Rr]esponse.*json' 2>/dev/null; then
    warn "Error internals may be exposed to client" \
         "Stack traces and internal error messages leak server details. Use generic messages."
  fi

  # SQL injection patterns (template literals in SQL)
  if echo "$ADDED_LINES" | grep -qE '(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE).*\$\{' 2>/dev/null; then
    warn "Possible SQL injection — template literal in SQL query" \
         "Use parameterized queries instead of string interpolation."
  fi

  # Debug artifacts
  if echo "$ADDED_LINES" | grep -qE '^\+.*debugger;' 2>/dev/null; then
    warn "debugger statement left in code" \
         "This will pause execution in browser dev tools."
  fi

fi

# ============================================================
# Large file detection (>1MB staged)
# ============================================================

for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    FILE_SIZE=$(wc -c < "$file" 2>/dev/null || echo "0")
    if [ "$FILE_SIZE" -gt 1048576 ]; then
      SIZE_MB=$(echo "scale=1; $FILE_SIZE / 1048576" | bc 2>/dev/null || echo ">1")
      warn "Large file staged: $file (${SIZE_MB}MB)" \
           "Binary blobs and data dumps shouldn't be in git. Use .gitignore or git-lfs."
    fi
  fi
done

# ============================================================
# Lockfile consistency check
# ============================================================

PKG_CHANGED=0
echo "$STAGED_FILES" | grep -q '^package\.json$' 2>/dev/null && PKG_CHANGED=1
LOCK_CHANGED=0
echo "$STAGED_FILES" | grep -qE '^(package-lock\.json|bun\.lock|yarn\.lock|pnpm-lock\.yaml)$' 2>/dev/null && LOCK_CHANGED=1

if [ "$PKG_CHANGED" -gt 0 ] && [ "$LOCK_CHANGED" -eq 0 ]; then
  # Only warn if package.json has dependency changes (not just scripts/metadata)
  PKG_DIFF=$(git diff --cached -U0 -- package.json 2>/dev/null || true)
  if echo "$PKG_DIFF" | grep -qE '^\+.*(dependencies|devDependencies)' 2>/dev/null; then
    warn "package.json dependencies changed but lockfile not updated" \
         "Run your package manager to update the lockfile before committing."
  fi
fi

# ============================================================
# Print warning summary (warnings don't block, just inform)
# ============================================================

if [ "$WARNINGS" -gt 0 ]; then
  echo "  $WARNINGS warning(s) found. Review before pushing."
  echo "  These are informational — the commit will proceed."
  echo ""
fi

# ============================================================
# Run any local repo-specific pre-commit hook
# ============================================================

LOCAL_HOOK="$(git rev-parse --show-toplevel 2>/dev/null)/.git/hooks/pre-commit.local"
if [ -f "$LOCAL_HOOK" ] && [ -x "$LOCAL_HOOK" ]; then
  "$LOCAL_HOOK" "$@"
fi

exit 0
