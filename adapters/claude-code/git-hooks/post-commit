#!/bin/bash
# Global post-commit hook — auto-deploys and auto-syncs Neural Lace.
#
# This runs after EVERY commit in EVERY repo (via core.hooksPath).
# It only takes action when the commit is inside the neural-lace repo.
#
# What it does for neural-lace commits:
#   1. Deploys to ~/.claude/ (install.sh)
#   2. Pushes to both remotes (sync.sh)

REPO_DIR="$(git rev-parse --show-toplevel 2>/dev/null)"

# Only act when committing inside neural-lace itself
if [[ "$REPO_DIR" != *"neural-lace"* ]]; then
  # Run any local repo-specific post-commit hook
  LOCAL_HOOK="$(git rev-parse --show-toplevel 2>/dev/null)/.git/hooks/post-commit.local"
  if [ -f "$LOCAL_HOOK" ] && [ -x "$LOCAL_HOOK" ]; then
    "$LOCAL_HOOK" "$@"
  fi
  exit 0
fi

INSTALLER="$REPO_DIR/adapters/claude-code/install.sh"
SYNCER="$REPO_DIR/sync.sh"

# 1. Auto-deploy to ~/.claude/
if [ -f "$INSTALLER" ]; then
  echo ""
  echo "Auto-deploying Neural Lace to ~/.claude/..."
  bash "$INSTALLER" 2>&1 | grep -E "(✓|✗|installed|hooksPath|already)"
  echo "Deploy complete."
fi

# 2. Auto-push to both remotes
if [ -f "$SYNCER" ]; then
  echo ""
  echo "Auto-syncing to remotes..."
  bash "$SYNCER" 2>&1 | grep -E "(✓|✗|synced|failed)"
fi

# 3. ask-rooted-workstreams-p1 Task 5a: best-effort `merged` progress-log
# emission for a LOCAL commit that just landed on master. ADDITIVE, not the
# guaranteed lane -- a remote squash-merge via `gh pr merge` never fires
# this hook at all; the auditor's git-scan (Task 5b/12, merge-scan-lib.sh's
# ms_scan_repo_for_merges) is the lane that actually guarantees coverage.
# Writer semantics (constraint 5): best-effort, never blocks this commit,
# every failure path silently swallowed (`|| true`, `>/dev/null 2>&1`).
(
  MS_LIB="$REPO_DIR/adapters/claude-code/hooks/lib/merge-scan-lib.sh"
  if [ -f "$MS_LIB" ]; then
    # shellcheck disable=SC1090
    . "$MS_LIB"
    if _ms_is_master_branch "$REPO_DIR" >/dev/null 2>&1; then
      _HEAD_SHA="$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null)"
      if [ -n "$_HEAD_SHA" ]; then
        ms_emit_merged_for_commit "$REPO_DIR" "$_HEAD_SHA" --emitter post-commit >/dev/null 2>&1
      fi
    fi
  fi
) >/dev/null 2>&1 || true

echo ""
